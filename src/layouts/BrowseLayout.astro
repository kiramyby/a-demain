---
import Footer from "@/components/Footer.astro";
import NavBar from "@/components/NavBar.astro";
import Layout from "./Layout.astro";
import "../styles/global.css";
---

<Layout>
  <div
    class="mx-auto h-full py-12 lg:grid lg:gap-x-8 lg:grid-cols-[240px_1fr] lg:grid-rows-[1fr_auto] flex flex-col lg:px-16 lg:py-0 lg:max-w-325"
  >
    <header class="lg:mb-2 lg:row-[1/2] lg:col-[1/2] mt-12">
      <NavBar />
    </header>
    <main class="lg:row-[1/3] lg:col-[2/3] flex-1 overflow-y-scroll h-screen">
      <slot />
    </main>
    <footer class="lg:row-[2/3] lg:col-[1/2] mb-12">
      <Footer />
    </footer>
  </div>
</Layout>
