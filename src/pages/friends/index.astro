---
import { SITE_FEATURES } from "@/config";
import BrowseLayout from "@/layouts/BrowseLayout.astro";
import { getFriendsPageView, loadFriendsPageState } from "@/lib/friends-page";
import { getActiveFriends } from "@/server/notion/friends/repository";

const state = await loadFriendsPageState(getActiveFriends, SITE_FEATURES.friends);
const view = getFriendsPageView(state);

if (view.responseStatus) {
	Astro.response.status = view.responseStatus.status;
	Astro.response.statusText = view.responseStatus.statusText;
}
---

<BrowseLayout>
  <section class="px-6 py-10 lg:px-10">
    <h1 class="text-4xl font-bold">{view.heading}</h1>

    {
      view.notice && (
        <p class="border-border bg-secondary-background mt-8 border-3 p-5">
          {view.notice}
        </p>
      )
    }

    {
      view.cards.length > 0 && (
        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {view.cards.map((friend) => (
            <article class="border-border bg-secondary-background border-3 p-5">
              <div class="flex gap-4">
                {friend.avatar && (
                  <img
                    class="border-border h-14 w-14 shrink-0 border-2 object-cover"
                    src={friend.avatar}
                    alt=""
                    loading="lazy"
                  />
                )}
                <div>
                  <h2 class="text-2xl font-bold">
                    {friend.url ? (
                      <a href={friend.url} target="_blank" rel="noreferrer" class="hover:underline">
                        {friend.name}
                      </a>
                    ) : (
                      friend.name
                    )}
                  </h2>
                  {friend.description && <p class="mt-2 text-sm">{friend.description}</p>}
                  {friend.group && <p class="mt-4 text-sm font-semibold">{friend.group}</p>}
                </div>
              </div>
            </article>
          ))}
        </div>
      )
    }
  </section>
</BrowseLayout>
