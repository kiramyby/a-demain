# Notion API Configuration
# Required for the blog content pipeline.
NOTION_API_KEY=your_notion_integration_token
NOTION_POSTS_DATABASE_ID=your_posts_database_id

# Optional: prefer a saved Notion view when it should define the result set.
NOTION_POSTS_VIEW_ID=

# Optional: otherwise use an explicit blog posts data source.
NOTION_POSTS_DATA_SOURCE_ID=

# Legacy optional compatibility config for non-blog Notion paths.
NOTION_FRIENDS_DATABASE_ID=your_friends_database_id
